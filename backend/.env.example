PORT=3000
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
AGENT_CONTEXT_WINDOW=6
AGENT_MAX_TOOL_CALLS=2
AGENT_TIMEOUT_MS=30000
AGENT_MAX_OUTPUT_TOKENS=1024
AGENT_DEBUG_LOGS=false
DISABLE_N8N_PATH=true

# Optional legacy n8n fallback (disabled by default)
N8N_WEBHOOK_URL=
N8N_API_KEY=
N8N_TIMEOUT_MS=90000
N8N_MAX_RETRIES=1
# Required for POST /api/internal/sharepoint-search (header x-internal-api-key)
INTERNAL_API_KEY=
# Optional: secret for POST /api/internal/sharepoint-search/reindex (defaults to N8N_API_KEY if unset)
SHAREPOINT_SEARCH_INTERNAL_KEY=
# Optional: absolute path to n8n-data if server cwd is not the backend folder
N8N_DATA_DIR=
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# ── Microsoft Graph API (SharePoint live search + file fetch) ──────────────────
# Create an App Registration in Azure AD → grant Files.Read.All + Sites.Read.All
# (Application permissions) → Grant admin consent.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
# Optional: restrict search to one SharePoint site
SHAREPOINT_SITE_ID=
