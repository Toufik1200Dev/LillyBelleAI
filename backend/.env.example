PORT=3000
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/company-assistant
N8N_API_KEY=your-n8n-api-key-here
N8N_TIMEOUT_MS=90000
N8N_MAX_RETRIES=1
# Required for POST /api/internal/sharepoint-search (header x-internal-api-key)
INTERNAL_API_KEY=
# Optional: secret for POST /api/internal/sharepoint-search/reindex (defaults to N8N_API_KEY if unset)
SHAREPOINT_SEARCH_INTERNAL_KEY=
# Optional: absolute path to n8n-data if server cwd is not the backend folder
N8N_DATA_DIR=
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20
