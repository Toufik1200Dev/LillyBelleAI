# Copy to .env (never commit .env). Values from Supabase → Settings → API.
# Project URL must be https://<ref>.supabase.co — NOT "your-project.supabase.co" (that host does not exist).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backend API (local dev)
VITE_API_URL=http://localhost:3000/api

# Optional: only if calling n8n directly from the browser
# VITE_N8N_WEBHOOK_URL=
# VITE_N8N_API_KEY=
